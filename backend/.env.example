# Smart Parking MN — орчны тохиргоо (хуулж .env болгоно)
PARKING_SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS
PARKING_DATABASE_URL=postgresql+psycopg2://parking:CHANGE_ME@localhost:5432/parking
PARKING_PUBLIC_BASE_URL=http://YOUR_SERVER_IP

# QPay merchant гэрээний мэдээлэл (developer.qpay.mn)
PARKING_QPAY_MOCK=true
PARKING_QPAY_USERNAME=
PARKING_QPAY_PASSWORD=
PARKING_QPAY_INVOICE_CODE=PARKING_INVOICE

# e-Barimt POS API 3.0 (татварын PosAPI сервисийг сервер дээр суулгасны дараа)
PARKING_EBARIMT_MOCK=true
PARKING_EBARIMT_POSAPI_URL=http://localhost:7080/rest
PARKING_EBARIMT_MERCHANT_TIN=
PARKING_EBARIMT_POS_NO=10000001
PARKING_EBARIMT_BRANCH_NO=001
PARKING_EBARIMT_DISTRICT_CODE=3420
PARKING_EBARIMT_CLASSIFICATION_CODE=5221190

# Dahua barrier (бодит төхөөрөмж холбогдмогц false)
PARKING_BARRIER_MOCK=true
PARKING_BARRIER_USERNAME=admin
PARKING_BARRIER_PASSWORD=

# ─── Аюулгүй байдал (production) ───
# QPay webhook хуурамчлахаас хамгаалах нууц токен (санамсаргүй урт мөр)
PARKING_QPAY_WEBHOOK_SECRET=
# Туршилтын simulate endpoint-ийг хаах (production-д false)
PARKING_ALLOW_SIMULATE=false
# CORS домэйн (олон бол таслалаар). "*" бол credentials унтарна
PARKING_CORS_ORIGINS=https://test.easy-parking.mn
